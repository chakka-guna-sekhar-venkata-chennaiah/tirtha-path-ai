# DeepSeek API — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Neo4j (local via Docker or Neo4j Desktop)
# Docker: docker run -e NEO4J_AUTH=neo4j/password -e NEO4J_PLUGINS='["graph-data-science"]' -p 7474:7474 -p 7687:7687 -d neo4j:5
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
